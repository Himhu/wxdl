/* ==================== 登录页样式 ==================== */

.login-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 50% 18%, rgba(62, 106, 225, 0.08), transparent 40%),
    linear-gradient(180deg, #FAFCFF 0%, #F5F7FB 50%, #F0F3F8 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 56rpx);
  box-sizing: border-box;
}

/* 主内容区 */
.login-main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateY(-72rpx);
}

/* 头像选择区 */
.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 144rpx;
  height: 144rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(62, 106, 225, 0.2);
}

.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7CF0 0%, #3E6AE1 55%, #2446A7 100%);
  box-shadow:
    0 24rpx 60rpx rgba(62, 106, 225, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
}

.avatar-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 标题 */
.title {
  font-size: 60rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: -1rpx;
  line-height: 1.2;
  margin-bottom: 16rpx;
  text-align: center;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
  text-align: center;
  letter-spacing: 2rpx;
  margin-bottom: 48rpx;
}

/* 昵称输入 */
.nickname-wrap {
  width: 100%;
  margin-bottom: 48rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 999rpx;
  padding: 0 36rpx;
  font-size: 30rpx;
  color: #111827;
  text-align: center;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.nickname-input:focus {
  border-color: #3E6AE1;
}

/* 微信登录按钮 */
.wechat-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #22C55E 0%, #16A34A 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow:
    0 20rpx 40rpx rgba(34, 197, 94, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.18);
}

.wechat-btn-hover {
  transform: scale(0.985);
  opacity: 0.96;
}

/* 提示文字 */
.hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

.footer-text {
  font-size: 22rpx;
  color: #C9CDD4;
}
