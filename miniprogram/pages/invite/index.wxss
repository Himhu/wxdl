page {
  background-color: var(--color-bg-page, #F2F3F5);
  height: 100vh;
}

.invite-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.poster-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  height: 100%;
  max-height: 72vh;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.06), 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  background-color: #FFFFFF;
}

.poster-skeleton {
  width: 80%;
  height: 68vh;
  border-radius: 32rpx;
  background-color: #E5E6E8;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}

.action-bar {
  display: flex;
  gap: 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.btn {
  flex: 1;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 28rpx;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.btn::after {
  display: none;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #333333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.btn-secondary:active {
  background-color: #F8F9FA;
}

.btn-primary {
  background-color: var(--color-brand-primary, #3E6AE1);
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(62, 106, 225, 0.25);
}

.btn-primary:active {
  opacity: 0.85;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
}
