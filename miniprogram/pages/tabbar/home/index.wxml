<view class="home-container">
  <!-- 顶部问候区 -->
  <view class="header">
    <view class="header-content">
      <view class="greeting">
        <view class="welcome-text">{{ isLogin ? (userInfo.nickname || '用户') : '访客' }}，你好</view>
        <view class="sub-text">今日数据概览</view>
      </view>
      <view wx:if="{{ !isLogin }}" class="login-btn" bindtap="onLogin">登录</view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section">
    <view class="stat-card" wx:for="{{ [{label:'总卡密',value:stats.totalCards,icon:'🗂'},{label:'已使用',value:stats.usedCards,icon:'✓'},{label:'积分余额',value:stats.balance,icon:'◈'}] }}" wx:key="label">
      <view class="stat-icon-box icon-box icon-box-{{ index === 0 ? 'brand' : index === 1 ? 'success' : 'warning' }}">
        <text class="stat-icon">{{ item.icon }}</text>
      </view>
      <view class="stat-info">
        <view class="stat-value num-font">{{ isLogin ? item.value : '--' }}</view>
        <view class="stat-label">{{ item.label }}</view>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section-container">
    <view class="section-header">
      <text class="section-title">快捷操作</text>
    </view>
    <view class="quick-actions">
      <view class="action-item" bindtap="onCardManage">
        <view class="action-icon-box icon-box icon-box-md icon-box-brand">
          <text class="action-icon">🗂</text>
        </view>
        <view class="action-content">
          <view class="action-title">创建卡密</view>
          <view class="action-desc">选择面值快速生成卡密</view>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <view class="action-item" bindtap="onRecharge" wx:if="{{ rechargeEnabled }}">
        <view class="action-icon-box icon-box icon-box-md icon-box-success">
          <text class="action-icon">◈</text>
        </view>
        <view class="action-content">
          <view class="action-title">充值积分</view>
          <view class="action-desc">为账户充值积分</view>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <view class="action-item" bindtap="onDestroyCards">
        <view class="action-icon-box icon-box icon-box-md icon-box-danger">
          <text class="action-icon">✕</text>
        </view>
        <view class="action-content">
          <view class="action-title">销毁卡密</view>
          <view class="action-desc">销毁未使用卡密并返还积分</view>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <view class="action-item" bindtap="onViewLogs">
        <view class="action-icon-box icon-box icon-box-md icon-box-warning">
          <text class="action-icon">☰</text>
        </view>
        <view class="action-content">
          <view class="action-title">操作日志</view>
          <view class="action-desc">查看操作记录</view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>
</view>
