<view class="profile-container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="avatar-section">
      <view class="avatar">
        <image wx:if="{{ userInfo.avatar }}" class="avatar-img" src="{{ userInfo.avatar }}" mode="aspectFill" />
        <text wx:else class="avatar-text">{{ displayAvatarText }}</text>
      </view>
      <view class="user-info">
        <view class="username">{{ displayNickname }}</view>
        <view class="user-tags">
          <view class="user-role-tag {{ roleTagClass }}">
            {{ roleText }}
          </view>
          <view class="agent-level-tag {{ agentLevel == 2 ? 'level-vip' : 'level-normal' }}" wx:if="{{ isAgent }}">
            {{ agentLevel == 2 ? 'VIP代理' : '普通代理' }}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 角色卡片 -->
  <view class="role-card" wx:if="{{ !isAgent }}" bindtap="onApplyAgent">
    <view class="role-card-left">
      <view class="role-icon-box">
        <text class="role-icon-text">🚀</text>
      </view>
      <view class="role-info">
        <view class="role-title">{{ hasPendingApplication ? '已提交申请，待审核' : '申请成为代理' }}</view>
        <view class="role-desc">{{ hasPendingApplication ? '申请已提交，等待管理员审核' : '提交申请后由管理员审核开通' }}</view>
      </view>
    </view>
  </view>

  <view class="role-card role-card-agent" wx:if="{{ isAgent }}" bindtap="onInviteAgent">
    <view class="role-card-left">
      <view class="role-icon-box role-icon-box-agent">
        <text class="role-icon-text">🎁</text>
      </view>
      <view class="role-info">
        <view class="role-title role-title-agent">邀请代理</view>
        <view class="role-desc role-desc-agent">分享邀请码，邀请好友加入</view>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view
        class="menu-item {{ item.itemClass }}"
        wx:for="{{ menuList }}"
        wx:key="title"
        data-url="{{ item.url }}"
        data-agent-only="{{ item.agentOnly }}"
        bindtap="onMenuTap"
      >
        <view class="menu-icon-box icon-box icon-box-md icon-box-brand">
          <text class="menu-icon-text">{{ item.iconText }}</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">{{ item.title }}</text>
          <text class="menu-lock" wx:if="{{ item.showLock }}">需代理权限</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" hover-class="logout-btn-hover" bindtap="onLogout">退出登录</button>
  </view>
</view>
