/* ==================== 卡密管理页样式 ==================== */
.cards-container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: var(--spacing-3xl);
}

/* --- 头部 --- */
.page-header {
  padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-md);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.page-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.page-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* --- Inset List 卡密列表 --- */
.card-list {
  background: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  margin: 0 var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
  overflow: hidden;
}

.card-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-md);
  position: relative;
  transition: background var(--transition-fast);
}

.card-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: var(--spacing-md);
  right: var(--spacing-md);
  height: 1rpx;
  background: var(--color-border-light);
}

.card-item:active {
  background: var(--color-bg-hover);
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-key-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-2xs);
}

.card-key {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  font-family: 'SF Mono', ui-monospace, 'Courier New', monospace;
  letter-spacing: 0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 420rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-2xs);
  flex-wrap: wrap;
}

.meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.card-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-text-quaternary);
  font-weight: 300;
  margin-left: var(--spacing-xs);
  flex-shrink: 0;
}

/* --- 空态 --- */
.empty-container {
  padding-top: 120rpx;
}

/* --- 分页加载 --- */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xl);
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand-primary);
  opacity: 0.6;
  animation: pulse 1.4s infinite ease-in-out;
}

.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

@keyframes pulse {
  0%, 100% { transform: scale(0.8); opacity: 0.4; }
  50% { transform: scale(1.2); opacity: 0.8; }
}

/* --- 头部创建按钮 --- */
.header-btn {
  font-size: 28rpx;
  color: #FFFFFF;
  background: var(--color-brand-primary);
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-weight: 500;
}

/* --- 复制按钮 --- */
.card-copy-btn {
  font-size: 24rpx;
  color: var(--color-brand-primary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--color-brand-primary);
  border-radius: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* --- 创建弹窗 --- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2329;
  text-align: center;
  margin-bottom: 8rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #86909C;
  text-align: center;
  margin-bottom: 32rpx;
}

.quota-input-wrap {
  margin-bottom: 32rpx;
}

.quota-input {
  width: 100%;
  height: 96rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn-cancel {
  background: #F3F5F9;
  color: #4E5969;
}

.modal-btn-confirm {
  background: var(--color-brand-primary);
  color: #FFFFFF;
}

.modal-btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.modal-close {
  text-align: center;
  font-size: 30rpx;
  color: #86909C;
  padding: 16rpx 0;
}
