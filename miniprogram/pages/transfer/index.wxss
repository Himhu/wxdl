page {
  background-color: var(--color-bg-page, #F2F3F5);
  min-height: 100vh;
}

.transfer-page {
  padding: 40rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #86909C;
  margin-bottom: 48rpx;
}

.input-group {
  margin-bottom: 28rpx;
}

.input-field {
  width: 100%;
  height: 96rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #1D2129;
  box-sizing: border-box;
}

.query-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #3E6AE1;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-top: 20rpx;
  border: none;
  box-shadow: 0 12rpx 24rpx rgba(62, 106, 225, 0.2);
}

.query-btn::after {
  display: none;
}

.query-btn:active {
  opacity: 0.85;
}

.hint-text {
  text-align: center;
  font-size: 24rpx;
  color: #C9CDD4;
  margin-top: 24rpx;
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.result-label {
  font-size: 28rpx;
  color: #86909C;
}

.result-value {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
}

.result-balance {
  font-size: 36rpx;
  font-weight: 700;
  color: #3E6AE1;
}

.result-agent-type {
  font-weight: 600;
  color: #1D2129;
}

.result-agent-type.vip {
  color: #FF7D00;
}

.transfer-actions {
  margin-top: 32rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1D2129;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.confirm-btn::after {
  display: none;
}

.success-box {
  margin-top: 32rpx;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  background: #ECFDF3;
}

.success-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #067647;
}

.success-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #3D8B6D;
}

.result-divider {
  height: 1rpx;
  background: #F2F3F5;
}
