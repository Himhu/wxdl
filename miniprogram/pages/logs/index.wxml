<wxs module="logUtils">
module.exports = {
  getType: function(action) {
    if (!action) return 'default';
    if (action.indexOf('登录') !== -1) return 'login';
    if (action.indexOf('余额') !== -1 || action.indexOf('充值') !== -1 || action.indexOf('转移') !== -1) return 'balance';
    return 'default';
  },
  getIconText: function(action) {
    if (!action) return '日';
    if (action.indexOf('登录') !== -1) return '登';
    if (action.indexOf('余额') !== -1 || action.indexOf('转移') !== -1) return '¥';
    if (action.indexOf('充值') !== -1) return '充';
    return '操';
  }
}
</wxs>

<view class="logs-container">
  <skeleton loading="{{ loading && logs.length === 0 }}" count="5" />

  <view class="log-list" wx:if="{{ logs.length > 0 }}">
    <view class="log-item" wx:for="{{ logs }}" wx:key="id">
      <view class="log-icon-container type-{{logUtils.getType(item.action)}}">
        <text class="log-icon-text">{{logUtils.getIconText(item.action)}}</text>
      </view>
      <view class="log-content">
        <view class="log-action">{{ item.action }}</view>
        <view class="log-detail" wx:if="{{ item.detail }}">{{ item.detail }}</view>
        <view class="log-footer">
          <text class="log-time">{{ item.createTime }}</text>
          <text class="log-operator" wx:if="{{ item.operator }}">{{ item.operator }}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-container" wx:elif="{{ !loading }}">
    <empty-state text="暂无操作日志" />
  </view>

  <view class="loading-more" wx:if="{{ loading && logs.length > 0 }}">
    <view class="loading-dot"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
