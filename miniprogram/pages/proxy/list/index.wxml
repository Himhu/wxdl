<view class="page-container">
  <!-- 骨架屏 -->
  <skeleton loading="{{ loading }}" count="4" />

  <block wx:if="{{ !loading }}">
    <!-- 邀请记录列表 -->
    <view class="proxy-list" wx:if="{{ proxyList.length > 0 }}">
      <view
        class="proxy-item"
        wx:for="{{ proxyList }}"
        wx:key="id"
        hover-class="proxy-item--active"
        hover-stay-time="80"
      >
        <view class="proxy-header">
          <view class="avatar">
            <image wx:if="{{ item.avatar }}" class="avatar-img" src="{{ item.avatar }}" mode="aspectFill" />
            <text wx:else>{{ item.avatarText }}</text>
          </view>
          <view class="proxy-info">
            <view class="name-row">
              <text class="proxy-name">{{ item.name }}</text>
              <view class="status-tag status-{{ item.status }}">{{ item.statusText }}</view>
            </view>
            <view class="invite-meta">邀请码：{{ item.inviteCode }}</view>
          </view>
        </view>

        <view class="metrics single-metric">
          <view class="metric-cell">
            <text class="metric-label">申请时间</text>
            <text class="metric-value metric-value-time">{{ item.displayTime }}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空态 -->
    <empty-state
      wx:if="{{ !proxyList.length }}"
      icon="○"
      text="暂无邀请记录"
      hint="邀请好友后会显示在这里"
    />

    <!-- 分页加载 -->
    <view class="load-more" wx:if="{{ hasMore }}">
      <text class="load-more__text">加载中...</text>
    </view>
  </block>
</view>
