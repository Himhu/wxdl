/* ==================== 我的下级页样式 ==================== */
.page-container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--spacing-md) 0 var(--spacing-3xl);
}

.proxy-list {
  background: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  margin: 0 var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
  overflow: hidden;
}

.proxy-item {
  padding: var(--spacing-md);
  position: relative;
  transition: background var(--transition-fast);
}

.proxy-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: var(--spacing-md);
  right: var(--spacing-md);
  height: 1rpx;
  background: var(--color-border-light);
}

.proxy-item--active {
  background: var(--color-bg-hover);
}

.proxy-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--gradient-brand);
  color: var(--color-text-onbrand);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.proxy-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.proxy-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.status-tag {
  padding: 2rpx var(--spacing-xs);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: 36rpx;
}

.status-approved {
  background: var(--color-success-soft);
  color: var(--color-success-text);
  border: 1rpx solid var(--color-success-border);
}

.status-pending {
  background: var(--color-warning-soft);
  color: var(--color-warning-text);
  border: 1rpx solid var(--color-warning-border);
}

.status-rejected {
  background: var(--color-danger-soft);
  color: var(--color-danger-text);
  border: 1rpx solid var(--color-danger-border);
}

.invite-meta {
  margin-top: 6rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.metrics {
  display: flex;
  align-items: center;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) 0;
}

.single-metric {
  justify-content: flex-start;
  padding: var(--spacing-sm) var(--spacing-md);
}

.metric-cell {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2xs);
}

.metric-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.metric-value {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.metric-value-time {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

.load-more {
  text-align: center;
  padding: var(--spacing-xl) 0 var(--spacing-lg);
}

.load-more__text {
  font-size: var(--font-size-sm);
  color: var(--color-text-quaternary);
}
