.station-switch {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  backdrop-filter: blur(10rpx);
}

.station-name {
  font-size: var(--font-size-sm);
  color: #FFFFFF;
  font-weight: var(--font-weight-medium);
  margin-right: 4rpx;
}

.station-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  opacity: 0.8;
}
